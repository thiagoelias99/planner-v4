generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  role          String?
  banned        Boolean?  @default(false)
  banReason     String?
  banExpires    DateTime?
  sessions      Session[]
  accounts      Account[]

  TickerOrders         TickerOrder[]
  FixedIncomes         FixedIncome[]
  otherAssets          OtherAsset[]
  assetBalanceStrategy AssetBalanceStrategy?
  portfolioHistories   PortfolioHistory[]

  @@unique([email])
  @@map("user")
}

model Session {
  id             String   @id
  expiresAt      DateTime
  token          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  ipAddress      String?
  userAgent      String?
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  impersonatedBy String?

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model Apikey {
  id                  String    @id
  configId            String    @default("default")
  name                String?
  start               String?
  referenceId         String
  prefix              String?
  key                 String
  refillInterval      Int?
  refillAmount        Int?
  lastRefillAt        DateTime?
  enabled             Boolean?  @default(true)
  rateLimitEnabled    Boolean?  @default(true)
  rateLimitTimeWindow Int?      @default(86400000)
  rateLimitMax        Int?      @default(10)
  requestCount        Int?      @default(0)
  remaining           Int?
  lastRequest         DateTime?
  expiresAt           DateTime?
  createdAt           DateTime
  updatedAt           DateTime
  permissions         String?
  metadata            String?

  @@index([configId])
  @@index([referenceId])
  @@index([key])
  @@map("apikey")
}

model Ticker {
  id            String   @id @default(cuid())
  symbol        String   @unique
  cnpj          String?
  name          String
  type          String
  price         Decimal  @db.Decimal(10, 2)
  change        Decimal? @default(0) @db.Decimal(10, 2)
  changePercent Decimal? @default(0) @map("change_percent") @db.Decimal(4, 3)
  autoUpdate    Boolean? @default(false) @map("auto_update")
  updatedAt     DateTime @updatedAt @map("updated_at")

  TickerOrders TickerOrder[]

  @@map("tickers")
}

model TickerOrder {
  id                    String   @id @default(cuid())
  userId                String   @map("user_id")
  ticker                String
  type                  String
  quantity              Int
  price                 Decimal  @db.Decimal(10, 2)
  previousMeanPrice     Decimal  @map("previous_mean_price") @db.Decimal(10, 2)
  previousTotalQuantity Int      @map("previous_total_quantity")
  newMeanPrice          Decimal  @map("new_mean_price") @db.Decimal(10, 2)
  newTotalQuantity      Int      @map("new_total_quantity")
  gainLoss              Decimal  @map("gain_loss") @db.Decimal(10, 2)
  createdAt             DateTime @default(now()) @map("created_at")
  updatedAt             DateTime @updatedAt @map("updated_at")

  User   User   @relation(fields: [userId], references: [id])
  Ticker Ticker @relation(fields: [ticker], references: [symbol])

  @@index([userId, ticker, type])
  @@map("ticker_orders")
}

model FixedIncome {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  description       String
  agency            String?
  note              String?
  initialInvestment Decimal   @map("initial_investment") @db.Decimal(10, 2)
  currentValue      Decimal   @map("current_value") @db.Decimal(10, 2)
  date              DateTime  @map("date")
  dueDate           DateTime  @map("due_date")
  fixedRate         Decimal   @default(0) @map("fixed_rate") @db.Decimal(10, 2)
  posFixedIndex     String    @default("NONE") @map("pos_fixed_index")
  retrievedAt       DateTime? @map("retrieved_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  User                  User                   @relation(fields: [userId], references: [id])
  PortfolioHistoryItems PortfolioHistoryItem[]

  @@map("fixed_incomes")
}

model OtherAsset {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  description String
  agency      String?
  note        String?
  value       Decimal  @db.Decimal(10, 2)
  type        String   @map("type")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  User                  User                   @relation(fields: [userId], references: [id])
  PortfolioHistoryItems PortfolioHistoryItem[]

  @@map("other_assets")
}

model AssetBalanceStrategy {
  id             String   @id @default(cuid())
  userId         String   @unique @map("user_id")
  notes          String?
  cashBox        Decimal  @default(10) @map("cash_box") @db.Decimal(10, 2)
  fixedIncome    Decimal  @default(10) @map("fixed_income") @db.Decimal(10, 2)
  variableIncome Decimal  @default(0) @map("variable_income") @db.Decimal(10, 2)
  pension        Decimal  @default(10) @db.Decimal(10, 2)
  property       Decimal  @default(10) @db.Decimal(10, 2)
  share          Decimal  @default(10) @db.Decimal(10, 2)
  reit           Decimal  @default(10) @db.Decimal(10, 2)
  international  Decimal  @default(10) @db.Decimal(10, 2)
  gold           Decimal  @default(10) @db.Decimal(10, 2)
  crypto         Decimal  @default(10) @db.Decimal(10, 2)
  other          Decimal  @default(10) @db.Decimal(10, 2)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  User User @relation(fields: [userId], references: [id])

  @@map("asset_balance_strategies")
}

model PortfolioHistory {
  id                                String   @id @default(cuid())
  userId                            String   @map("user_id")
  snapshotDate                      DateTime @map("snapshot_date")
  variableIncomeTotalInvested       Decimal  @default(0) @map("variable_income_total_invested") @db.Decimal(12, 2)
  variableIncomeTotalBalance        Decimal  @default(0) @map("variable_income_total_balance") @db.Decimal(12, 2)
  shareTotalBalance                 Decimal  @default(0) @map("share_total_balance") @db.Decimal(12, 2)
  reitTotalBalance                  Decimal  @default(0) @map("reit_total_balance") @db.Decimal(12, 2)
  internationalTotalBalance         Decimal  @default(0) @map("international_total_balance") @db.Decimal(12, 2)
  goldTotalBalance                  Decimal  @default(0) @map("gold_total_balance") @db.Decimal(12, 2)
  cryptoTotalBalance                Decimal  @default(0) @map("crypto_total_balance") @db.Decimal(12, 2)
  genericVariableIncomeTotalBalance Decimal  @default(0) @map("generic_variable_income_total_balance") @db.Decimal(12, 2)
  cashTotalBalance                  Decimal  @default(0) @map("cash_total_balance") @db.Decimal(12, 2)
  pensionTotalBalance               Decimal  @default(0) @map("pension_total_balance") @db.Decimal(12, 2)
  fixedIncomeTotalBalance           Decimal  @default(0) @map("fixed_income_total_balance") @db.Decimal(12, 2)
  propertyTotalBalance              Decimal  @default(0) @map("property_total_balance") @db.Decimal(12, 2)
  otherTotalBalance                 Decimal  @default(0) @map("other_total_balance") @db.Decimal(12, 2)
  totalBalance                      Decimal  @default(0) @map("total_balance") @db.Decimal(12, 2)
  assetBalanceStrategySnapshot      String?  @map("asset_balance_strategy_snapshot")
  createdAt                         DateTime @default(now()) @map("created_at")

  User                  User                   @relation(fields: [userId], references: [id])
  PortfolioHistoryItems PortfolioHistoryItem[]

  @@index([userId, snapshotDate])
  @@map("portfolio_histories")
}

model PortfolioHistoryItem {
  id                 String    @id @default(cuid())
  portfolioHistoryId String    @map("portfolio_history_id")
  fixedIncomeId      String?   @map("fixed_income_id")
  otherAssetId       String?   @map("other_asset_id")
  type               String
  description        String
  agency             String?
  note               String?
  value              Decimal   @db.Decimal(12, 2)
  dueDate            DateTime? @map("due_date")
  fixedRate          Decimal?  @map("fixed_rate") @db.Decimal(10, 2)
  posFixedIndex      String?   @map("pos_fixed_index")
  createdAt          DateTime  @default(now()) @map("created_at")

  PortfolioHistory PortfolioHistory @relation(fields: [portfolioHistoryId], references: [id], onDelete: Cascade)
  FixedIncome      FixedIncome?     @relation(fields: [fixedIncomeId], references: [id])
  OtherAsset       OtherAsset?      @relation(fields: [otherAssetId], references: [id])

  @@index([portfolioHistoryId])
  @@map("portfolio_history_items")
}
