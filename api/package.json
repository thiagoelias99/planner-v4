    "@prisma/client": "^6.19.3",
    "@react-email/components": "^1.0.12",
    "@rekog/mcp-nest": "^1.9.9",
    "@thallesp/nestjs-better-auth": "^2.6.0",
    "argon2": "^0.44.0",
    "axios": "^1.15.2",
    "better-auth": "^1.6.9",
    "bullmq": "^5.76.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "date-fns": "^4.1.0",
