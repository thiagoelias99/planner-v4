# =================================
# Configuração geral da aplicação
# =================================
## Ambiente de execução da aplicação (development, production, etc)
NODE_ENV="development"
## Runtime do Next.js (nodejs, edge)
NEXT_RUNTIME="nodejs"
## URL pública da aplicação Next.js
NEXT_PUBLIC_URL="http://localhost:3000"
## Email do administrador do sistema
ADMIN_EMAIL="admin@email.com"
## Senha do administrador do sistema
ADMIN_PASSWORD="Admin12345"
## API URL do backend NestJS
API_URL="http://localhost:3333/v1"
## Chave da API para acesso a funcionalidades protegidas
API_KEY="my_api_key_123"

# =================================
# Configuração do banco de dados
# =================================
## URL de conexão com o banco de dados PostgreSQL
DATABASE_URL="postgresql://docker:docker@localhost:5432/connect"

# =================================
# Configuração de autenticação
# =================================
## Chave secreta usada para autenticação
BETTER_AUTH_SECRET="1234567890abcdefghijklmnopqrstuvwxyz"
## URL do serviço de autenticação
BETTER_AUTH_URL="http://localhost:3000"
## ID do cliente Google para autenticação social
GOOGLE_CLIENT_ID=""
## Segredo do cliente Google para autenticação social
GOOGLE_CLIENT_SECRET=""

# =================================
# Configuração Resend (Opcional)
# =================================
RESEND_API_KEY=""
RESEND_DOMAIN=""
ENABLE_EMAIL_SERVICE="false"

# =================================
# Configuração S3 (Opcional)
# =================================
AWS_ACCESS_KEY_ID="docker"
AWS_SECRET_ACCESS_KEY="docker123"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="uploads"
AWS_S3_URL="http://localhost:9000"
